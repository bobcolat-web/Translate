UDim2.new(0.8, 0, 0, 25)LangInput.BackgroundColor3 = Color3.fromRGB(50, 50, 50)LangInput.PlaceholderText = "Lang (e.g. en, es, fr)"LangInput.Text = "en"LangInput.TextColor3 = Color3.fromRGB(255, 255, 255)LangInput.Font = Enum.Font.GothamStatusLabel.Parent = MainFrameStatusLabel.Position = UDim2.new(0, 0, 0.8, 0)StatusLabel.Size = UDim2.new(1, 0, 0, 20)StatusLabel.BackgroundTransparency = 1StatusLabel.Text = "Ready to translate"StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)StatusLabel.TextSize = 10-- Translation Functionlocal function Translate(text, target)if not Config.Enabled or text == "" then return nil endif Config.Cache[text] then return Config.Cache[text] endlocal url = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl="..target.."&dt=t&q="..HttpService:UrlEncode(text)
local success, response = pcall(function()
    return game:HttpGet(url)
end)

if success then
    local data = HttpService:JSONDecode(response)
    local translatedText = ""
    for _, v in pairs(data[1]) do
        translatedText = translatedText .. v[1]
    end
    Config.Cache[text] = translatedText
    return translatedText
end
return nil
end-- Handling Chat Displayslocal function DisplayTranslation(senderName, originalText, translatedText)if not translatedText or translatedText == originalText then return endlocal format = string.format("[%s]: %s", senderName, translatedText)
game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
    Text = "{TRANS} " .. format,
    Color = Color3.fromRGB(255, 200, 50),
    Font = Enum.Font.GothamMedium
})
end-- 1. Modern Chat (TextChatService)TextChatService.OnIncomingMessage = function(message)if not Config.Enabled then return endif message.TextSource and message.Status == Enum.TextChatMessageStatus.Success thenlocal sender = message.TextSource.Nameif sender ~= LocalPlayer.Name thentask.spawn(function()local result = Translate(message.Text, Config.TargetLang)if result thenDisplayTranslation(sender, message.Text, result)endend)endendend-- 2. Legacy Chat (Old School)local function HookLegacy()local chatEvents = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents")if chatEvents thenlocal messageEvent = chatEvents:FindFirstChild("OnMessageDoneFiltering")if messageEvent and messageEvent:IsA("RemoteEvent") thenmessageEvent.OnClientEvent:Connect(function(data)if not Config.Enabled then return endlocal sender = data.FromSpeakerlocal msg = data.Messageif sender ~= LocalPlayer.Name thentask.spawn(function()local result = Translate(msg, Config.TargetLang)if result thenDisplayTranslation(sender, msg, result)endend)endend)endendend-- UI LogicToggleBtn.MouseButton1Click:Connect(function()Config.Enabled = not Config.EnabledToggleBtn.Text = Config.Enabled and "Status: ON" or "Status: OFF"ToggleBtn.BackgroundColor3 = Config.Enabled and Color3.fromRGB(60, 180, 110) or Color3.fromRGB(180, 60, 60)end)LangInput.FocusLost:Connect(function()Config.TargetLang = LangInput.Text:lower()StatusLabel.Text = "Target language set to: " .. Config.TargetLangend)-- InitializationHookLegacy()print("[Delta Translator] Loaded successfully.")
