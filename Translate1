--[[
    Advanced Russian-to-English Chat Translator
    Optimized for Delta Executor
    
    Features:
    - Auto-detects Cyrillic (Russian) characters.
    - Bypasses Roblox's internal translation lag.
    - Works with both TextChatService and Legacy Chat.
]]

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local TextChatService = game:GetService("TextChatService")
local LocalPlayer = Players.LocalPlayer

-- Configuration
local TARGET_LANG = "en"
local SHOW_ORIGINAL = true -- Set to false to only see the translation

-- Helper function to detect Russian characters (Cyrillic range)
local function isRussian(text)
    return text:find("[%z\1-\127]") == nil or text:match("[%cyrillic%]+") ~= nil or text:match("[\208-\211]")
end

-- Translation Function using a public API
local function translate(text)
    local url = "https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl="..TARGET_LANG.."&dt=t&q="..HttpService:UrlEncode(text)
    local success, response = pcall(function()
        return HttpService:GetAsync(url)
    end)
    
    if success then
        local data = HttpService:JSONDecode(response)
        if data and data[1] and data[1][1] then
            return data[1][1][1]
        end
    end
    return nil
end

-- Display function to show the translated text in your chat
local function displayTranslation(senderName, original, translated)
    local message = string.format("[%s]: %s", senderName, translated)
    
    -- Try modern TextChatService first
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local channel = TextChatService.TextChannels.RBXGeneral
        channel:DisplaySystemMessage("<font color='#55FF55'>[TRANSLATED] </font>" .. message)
    else
        -- Fallback to Legacy Chat
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[TRANSLATED] " .. message,
            Color = Color3.fromRGB(85, 255, 85),
            Font = Enum.Font.SourceSansBold
        })
    end
end

-- Handle incoming messages
local function onMessage(messageText, sender)
    if sender == LocalPlayer then return end
    
    if isRussian(messageText) then
        task.spawn(function()
            local translated = translate(messageText)
            if translated and translated:lower() ~= messageText:lower() then
                displayTranslation(sender.Name, messageText, translated)
            end
        end)
    end
end

-- Hook into TextChatService
TextChatService.OnIncomingMessage = function(message)
    if message.TextSource then
        local sender = Players:GetPlayerByUserId(message.TextSource.UserId)
        if sender then
            onMessage(message.Text, sender)
        end
    end
end

-- Also hook into older Chat systems via RemoteEvents if necessary
for _, v in pairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
    if v:IsA("RemoteEvent") and v.Name == "DefaultChatSystemChatEvents" then
        v.OnClientEvent:Connect(function(data)
            if data and data.SpeakerUserId then
                local sender = Players:GetPlayerByUserId(data.SpeakerUserId)
                onMessage(data.Message, sender)
            end
        end)
    end
end

print("Russian Chat Translator Loaded Successfully.")
